export DOTFILES="$HOME/.dotfiles"

dotfiles-push() {
  cd "$DOTFILES" && git add -A && git commit -m "${1:-.}" && git push
}

dotfiles-update() {
  cd "$DOTFILES" && git pull
}

dotfiles-install(){
  cd "$DOTFILES" && ./install.sh
}

alias claude-unsafe='claude --allow-dangerously-skip-permissions'

export CLICOLOR=1
export DROPBOX="$HOME/Dropbox" 	# NOTE: might be linked type
export PATH="$HOME/.local/bin/:$PATH"
export PATH="$HOME/.fzf/bin/:$PATH"


# bun completions
[ -s "/Users/lim/.bun/_bun" ] && source "/Users/lim/.bun/_bun"

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"


