{
  "global": { "show_in_menu_bar": false },
  "profiles": [
    {
      "complex_modifications": {
        "parameters": {
          "basic.simultaneous_threshold_milliseconds": 150,
          "basic.to_if_alone_timeout_milliseconds": 130,
          "basic.to_if_held_down_threshold_milliseconds": 150
        },
        "rules": [
          {
            "description": "Change control-h to delete",
            "manipulators": [
              {
                "from": {
                  "key_code": "h",
                  "modifiers": {
                    "mandatory": ["control"],
                    "optional": ["caps_lock", "option"]
                  }
                },
                "to": [{ "key_code": "delete_or_backspace" }],
                "type": "basic"
              }
            ]
          },
          {
            "description": "Home row mod",
            "enabled": false,
            "manipulators": [
              {
                "description": "d -> cmd",
                "from": {
                  "key_code": "d",
                  "modifiers": { "optional": ["any"] }
                },
                "to": [
                  {
                    "key_code": "left_command",
                    "lazy": true
                  }
                ],
                "to_if_alone": [{ "key_code": "d" }],
                "type": "basic"
              },
              {
                "description": "spacebar -> spacebar/shift",
                "from": {
                  "key_code": "spacebar",
                  "modifiers": { "optional": ["any"] }
                },
                "to": [
                  {
                    "key_code": "left_shift",
                    "lazy": true
                  }
                ],
                "to_if_alone": [{ "key_code": "spacebar" }],
                "type": "basic"
              },
              {
                "description": "Shift -> f18 (Input mode switch)",
                "form": { "key_code": "left_shift" },
                "to_if_alone": [{ "key_code": "f18" }],
                "to_if_held_down": [{ "key_code": "left_shift" }],
                "type": "basic"
              }
            ]
          },
          {
            "description": "Open app by right shift + [key]",
            "manipulators": [
              {
                "description": "Right Command + w: Google Chrome",
                "from": {
                  "key_code": "w",
                  "modifiers": { "mandatory": ["right_shift"] }
                },
                "to": [
                  {
                    "software_function": {
                      "open_application": {
                        "file_path": "/Applications/Google Chrome.app"
                      }
                    }
                  }
                ],
                "type": "basic"
              },
              {
                "description": "Right Command + c: Visual Studio Code",
                "from": {
                  "key_code": "c",
                  "modifiers": { "mandatory": ["right_shift"] }
                },
                "to": [
                  {
                    "software_function": {
                      "open_application": {
                        "file_path": "/Applications/Visual Studio Code.app"
                      }
                    }
                  }
                ],
                "type": "basic"
              },
              {
                "description": "Right Command + t: Ghostty",
                "from": {
                  "key_code": "t",
                  "modifiers": { "mandatory": ["right_shift"] }
                },
                "to": [
                  {
                    "software_function": {
                      "open_application": {
                        "file_path": "/Applications/Ghostty.app"
                      }
                    }
                  }
                ],
                "type": "basic"
              }
            ]
          },
          {
            "description": "ctrl+a/e",
            "enabled": true,
            "manipulators": [
              {
                "from": {
                  "key_code": "a",
                  "modifiers": { "mandatory": ["left_control"] }
                },
                "to": [
                  {
                    "key_code": "left_arrow",
                    "modifiers": ["command"]
                  }
                ],
                "type": "basic"
              },
              {
                "from": {
                  "key_code": "e",
                  "modifiers": { "mandatory": ["left_control"] }
                },
                "to": [
                  {
                    "key_code": "right_arrow",
                    "modifiers": ["command"]
                  }
                ],
                "type": "basic"
              }
            ]
          },
          {
            "description": "ctrl+bnpf",
            "enabled": true,
            "manipulators": [
              {
                "from": {
                  "key_code": "b",
                  "modifiers": {
                    "mandatory": ["left_control"],
                    "optional": ["shift"]
